{
  "uid": "claims-slo-overview",
  "title": "SLO / SLI / SLA Overview",
  "description": "Service Level Objectives, Indicators, and Agreements for the Claims Processor platform",
  "tags": ["claims-processor", "sre"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 39,
  "fiscalYearStartMonth": 0,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" },
        "hide": 0
      },
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(http_server_requests_seconds_count, application)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "slo_window",
        "type": "custom",
        "query": "5m,1h,6h,1d,7d,14d,30d",
        "current": { "text": "1h", "value": "1h" },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "SLO Summary",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "id": 1
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Current Availability %",
      "description": "SLO Target: 99.9%",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.99 },
              { "color": "yellow", "value": 0.995 },
              { "color": "green", "value": 0.999 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "1 - (\n  sum(rate(http_server_requests_seconds_count{application=~\"$service\", status=~\"5..\"}[$slo_window]))\n  /\n  sum(rate(http_server_requests_seconds_count{application=~\"$service\"}[$slo_window]))\n)",
          "legendFormat": "Availability"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Current p99 Latency",
      "description": "SLO Target: < 500ms",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "orange", "value": 0.5 },
              { "color": "red", "value": 1.0 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=~\"$service\"}[5m])) by (le))",
          "legendFormat": "p99 Latency"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Current p95 Latency",
      "description": "SLO Target: < 200ms",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.15 },
              { "color": "orange", "value": 0.2 },
              { "color": "red", "value": 0.5 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=~\"$service\"}[5m])) by (le))",
          "legendFormat": "p95 Latency"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Error Budget Remaining %",
      "description": "Remaining error budget for the current SLO window",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.1 },
              { "color": "yellow", "value": 0.25 },
              { "color": "green", "value": 0.5 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "1 - (\n  (\n    1 - (\n      sum(rate(http_server_requests_seconds_count{application=~\"$service\", status=~\"5..\"}[$slo_window]))\n      /\n      sum(rate(http_server_requests_seconds_count{application=~\"$service\"}[$slo_window]))\n    )\n  ) / 0.999\n) / (1 - 0.999) * (1 - 0.999)",
          "legendFormat": "Error Budget Remaining"
        }
      ]
    },
    {
      "type": "row",
      "title": "Availability SLO",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "collapsed": false,
      "id": 6
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Availability % Over Time",
      "description": "Rolling availability with 99.9% SLO target line",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "min": 0.99,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "spanNulls": false,
            "showPoints": "never",
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" },
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0.999 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "min"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "1 - (\n  sum(rate(http_server_requests_seconds_count{application=~\"$service\", status=~\"5..\"}[5m]))\n  /\n  sum(rate(http_server_requests_seconds_count{application=~\"$service\"}[5m]))\n)",
          "legendFormat": "Availability %"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Error Rate Over Time",
      "description": "Rate of 5xx errors across services",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "spanNulls": false,
            "showPoints": "never",
            "axisLabel": ""
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (application) (rate(http_server_requests_seconds_count{application=~\"$service\", status=~\"5..\"}[5m]))",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Latency SLO",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "collapsed": false,
      "id": 9
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "p99 Latency Over Time",
      "description": "99th percentile latency with 500ms SLO target",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "spanNulls": false,
            "showPoints": "never",
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum by (le, application) (rate(http_server_requests_seconds_bucket{application=~\"$service\"}[5m])))",
          "legendFormat": "{{application}} p99"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "p95 Latency Over Time",
      "description": "95th percentile latency with 200ms SLO target",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "spanNulls": false,
            "showPoints": "never",
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.2 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (le, application) (rate(http_server_requests_seconds_bucket{application=~\"$service\"}[5m])))",
          "legendFormat": "{{application}} p95"
        }
      ]
    },
    {
      "type": "row",
      "title": "Error Budget",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "collapsed": false,
      "id": 12
    },
    {
      "id": 13,
      "type": "gauge",
      "title": "Error Budget Remaining (30-day window)",
      "description": "Percentage of error budget remaining based on 99.9% SLO over a 30-day rolling window",
      "gridPos": { "h": 9, "w": 8, "x": 0, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.1 },
              { "color": "yellow", "value": 0.25 },
              { "color": "green", "value": 0.5 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "clamp_min(\n  1 - (\n    sum(increase(http_server_requests_seconds_count{application=~\"$service\", status=~\"5..\"}[30d]))\n    /\n    (sum(increase(http_server_requests_seconds_count{application=~\"$service\"}[30d])) * (1 - 0.999))\n  ),\n  0\n)",
          "legendFormat": "Error Budget Remaining"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Error Budget Burn Rate",
      "description": "Rate at which the error budget is being consumed. Values >1 indicate the budget is being consumed faster than allowed.",
      "gridPos": { "h": 9, "w": 16, "x": 8, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "spanNulls": false,
            "showPoints": "never",
            "thresholdsStyle": { "mode": "line+area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "refId": "fast_burn",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "(\n  sum(rate(http_server_requests_seconds_count{application=~\"$service\", status=~\"5..\"}[1h]))\n  /\n  sum(rate(http_server_requests_seconds_count{application=~\"$service\"}[1h]))\n) / (1 - 0.999)",
          "legendFormat": "1h burn rate (fast)"
        },
        {
          "refId": "slow_burn",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "(\n  sum(rate(http_server_requests_seconds_count{application=~\"$service\", status=~\"5..\"}[6h]))\n  /\n  sum(rate(http_server_requests_seconds_count{application=~\"$service\"}[6h]))\n) / (1 - 0.999)",
          "legendFormat": "6h burn rate (slow)"
        }
      ]
    }
  ],
  "annotations": {
    "list": [
      {
        "name": "Deployments",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "enable": true,
        "iconColor": "blue",
        "expr": "changes(process_start_time_seconds{application=~\"$service\"}[5m]) > 0",
        "titleFormat": "Service Restart",
        "textFormat": "{{application}} restarted"
      }
    ]
  }
}