{
  "uid": "claims-auth-resilience",
  "title": "Authentication & Resilience",
  "description": "Authentication error monitoring, inter-service communication, circuit breakers, bulkheads, and connection pool health",
  "tags": ["claims-processor", "sre", "security"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 39,
  "fiscalYearStartMonth": 0,
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"]
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" },
        "hide": 0
      },
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(http_server_requests_seconds_count, application)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Authentication",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "id": 1
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Auth Success vs Failure Rate",
      "description": "Compares successful (2xx) request rate against authentication (401) and authorization (403) failure rates",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never",
            "axisPlacement": "auto"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*401.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*403.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(http_server_requests_seconds_count{application=~\"$service\", status=~\"2..\"}[5m]))",
          "legendFormat": "2xx Success"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(http_server_requests_seconds_count{application=~\"$service\", status=\"401\"}[5m]))",
          "legendFormat": "401 Authentication Failures"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(http_server_requests_seconds_count{application=~\"$service\", status=\"403\"}[5m]))",
          "legendFormat": "403 Authorization Failures"
        }
      ]
    },
    {
      "id": 3,
      "type": "barchart",
      "title": "Auth Failure Rate per Service",
      "description": "Authentication and authorization failure rate broken down by service",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "axisCenteredZero": false
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.03 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "auto",
        "groupWidth": 0.7,
        "barWidth": 0.9,
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (application) (rate(http_server_requests_seconds_count{application=~\"$service\", status=~\"401|403\"}[5m])) / sum by (application) (rate(http_server_requests_seconds_count{application=~\"$service\"}[5m]))",
          "legendFormat": "{{application}}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": { "Value": "Failure Rate", "application": "Service" }
          }
        }
      ]
    },
    {
      "id": 4,
      "type": "table",
      "title": "Top Failed Endpoints (401/403)",
      "description": "Endpoints with the highest authentication and authorization failure counts",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Failures/sec" },
              { "id": "unit", "value": "reqps" },
              { "id": "custom.displayMode", "value": "color-background" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "transparent", "value": null },
                    { "color": "orange", "value": 0.1 },
                    { "color": "red", "value": 1 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Failures/sec", "desc": true }],
        "footer": { "show": false }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "topk(20, sum by (application, uri, status) (rate(http_server_requests_seconds_count{application=~\"$service\", status=~\"401|403\"}[5m])))",
          "legendFormat": "",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": { "application": "Service", "uri": "Endpoint", "status": "Status" }
          }
        }
      ]
    },
    {
      "type": "row",
      "title": "Inter-Service Communication",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false,
      "id": 5
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Outgoing HTTP Call Latency (p50/p95/p99)",
      "description": "Latency percentiles for outgoing HTTP client calls to downstream services",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, sum by (le, uri) (rate(http_client_requests_seconds_bucket{application=~\"$service\"}[5m])))",
          "legendFormat": "p50 {{uri}}"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (le, uri) (rate(http_client_requests_seconds_bucket{application=~\"$service\"}[5m])))",
          "legendFormat": "p95 {{uri}}"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum by (le, uri) (rate(http_client_requests_seconds_bucket{application=~\"$service\"}[5m])))",
          "legendFormat": "p99 {{uri}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Outgoing Call Error Rate per Target",
      "description": "Percentage of outgoing HTTP calls failing (5xx) per target URI",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (application, uri) (rate(http_client_requests_seconds_count{application=~\"$service\", status=~\"5..\"}[5m])) / sum by (application, uri) (rate(http_client_requests_seconds_count{application=~\"$service\"}[5m]))",
          "legendFormat": "{{application}} -> {{uri}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Call Volume per Target",
      "description": "Total outgoing HTTP request rate per target URI",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (application, uri) (rate(http_client_requests_seconds_count{application=~\"$service\"}[5m]))",
          "legendFormat": "{{application}} -> {{uri}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Circuit Breaker Status",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false,
      "id": 9
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Circuit Breaker State",
      "description": "Current state of each circuit breaker instance (green=closed, red=open, yellow=half-open)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CLOSED", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "OPEN", "color": "red" } } },
            { "type": "value", "options": { "2": { "text": "HALF_OPEN", "color": "yellow" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "horizontal"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "resilience4j_circuitbreaker_state{application=~\"$service\", state=\"open\"}",
          "legendFormat": "{{application}} / {{name}}"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Circuit Breaker Failure Rate",
      "description": "Failure rate tracked by each circuit breaker",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.3 },
              { "color": "red", "value": 0.5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "resilience4j_circuitbreaker_failure_rate{application=~\"$service\"} / 100",
          "legendFormat": "{{application}} / {{name}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Circuit Breaker State Transitions",
      "description": "Rate of circuit breaker state transitions over time",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 80,
            "showPoints": "never",
            "stacking": { "mode": "normal", "group": "A" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "increase(resilience4j_circuitbreaker_calls_total{application=~\"$service\", kind=\"successful\"}[5m])",
          "legendFormat": "{{name}} successful"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "increase(resilience4j_circuitbreaker_calls_total{application=~\"$service\", kind=\"failed\"}[5m])",
          "legendFormat": "{{name}} failed"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "increase(resilience4j_circuitbreaker_calls_total{application=~\"$service\", kind=\"not_permitted\"}[5m])",
          "legendFormat": "{{name}} not_permitted"
        }
      ]
    },
    {
      "type": "row",
      "title": "Bulkhead & Rate Limiter",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "collapsed": false,
      "id": 13
    },
    {
      "id": 14,
      "type": "gauge",
      "title": "Bulkhead Active Calls vs Max",
      "description": "Current active concurrent calls as a fraction of bulkhead max allowed",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.6 },
              { "color": "orange", "value": 0.8 },
              { "color": "red", "value": 0.95 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "resilience4j_bulkhead_available_concurrent_calls{application=~\"$service\"} / (resilience4j_bulkhead_available_concurrent_calls{application=~\"$service\"} + resilience4j_bulkhead_max_allowed_concurrent_calls{application=~\"$service\"})",
          "legendFormat": "{{application}} / {{name}}"
        }
      ]
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Bulkhead Rejected Calls",
      "description": "Rate of calls rejected by the bulkhead due to concurrent call limits",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 80,
            "showPoints": "never"
          },
          "color": { "fixedColor": "red", "mode": "fixed" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (application, name) (rate(resilience4j_bulkhead_calls_total{application=~\"$service\", kind=\"rejected\"}[5m]))",
          "legendFormat": "{{application}} / {{name}}"
        }
      ]
    },
    {
      "id": 16,
      "type": "gauge",
      "title": "Rate Limiter Available Permissions",
      "description": "Available permissions in each rate limiter instance",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "green", "value": 20 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "resilience4j_ratelimiter_available_permissions{application=~\"$service\"}",
          "legendFormat": "{{application}} / {{name}}"
        }
      ]
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Rate Limiter Rejected Calls",
      "description": "Rate of calls rejected by the rate limiter",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 80,
            "showPoints": "never"
          },
          "color": { "fixedColor": "orange", "mode": "fixed" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (application, name) (rate(resilience4j_ratelimiter_calls_total{application=~\"$service\", kind=\"failed\"}[5m]))",
          "legendFormat": "{{application}} / {{name}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "HikariCP Connection Pool",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "collapsed": false,
      "id": 18
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "Active Connections vs Max per Service",
      "description": "HikariCP active database connections compared to configured maximum",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 37 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "hikaricp_connections_active{application=~\"$service\"}",
          "legendFormat": "{{application}} active"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "hikaricp_connections_max{application=~\"$service\"}",
          "legendFormat": "{{application}} max"
        }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Pending Connection Requests",
      "description": "Threads waiting to acquire a database connection from HikariCP",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 37 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 3 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "hikaricp_connections_pending{application=~\"$service\"}",
          "legendFormat": "{{application}} pending"
        }
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Connection Acquire Time",
      "description": "Time spent acquiring a connection from the HikariCP pool",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 37 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(hikaricp_connections_acquire_seconds_sum{application=~\"$service\"}[5m]) / rate(hikaricp_connections_acquire_seconds_count{application=~\"$service\"}[5m])",
          "legendFormat": "{{application}} avg acquire"
        }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Connection Usage Time",
      "description": "Time spent using a borrowed connection before returning it to the pool",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 37 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(hikaricp_connections_usage_seconds_sum{application=~\"$service\"}[5m]) / rate(hikaricp_connections_usage_seconds_count{application=~\"$service\"}[5m])",
          "legendFormat": "{{application}} avg usage"
        }
      ]
    }
  ],
  "annotations": {
    "list": [
      {
        "name": "Deployments",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "enable": true,
        "iconColor": "blue",
        "expr": "changes(process_start_time_seconds{application=~\"$service\"}[5m]) > 0",
        "titleFormat": "Service Restart",
        "textFormat": "{{application}} restarted"
      }
    ]
  }
}