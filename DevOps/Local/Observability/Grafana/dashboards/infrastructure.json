{
  "uid": "claims-infrastructure",
  "title": "Infrastructure",
  "description": "Infrastructure metrics for PostgreSQL, Redis, Kafka, and Elasticsearch backing the Claims Processor platform",
  "tags": ["claims-processor", "sre"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 39,
  "fiscalYearStartMonth": 0,
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"]
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Database (PostgreSQL)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "id": 1
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "PostgreSQL Active Connections",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pg_stat_activity_count{state=\"active\"}",
          "legendFormat": "active"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pg_stat_activity_count{state=\"idle\"}",
          "legendFormat": "idle"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pg_settings_max_connections",
          "legendFormat": "max_connections"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Query Execution Time",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(pg_stat_user_tables_seq_scan{datname=\"claims\"}[5m])",
          "legendFormat": "seq scans/s - {{relname}}"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(pg_stat_user_tables_idx_scan{datname=\"claims\"}[5m])",
          "legendFormat": "idx scans/s - {{relname}}"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(pg_stat_statements_mean_exec_time_ms[5m])",
          "legendFormat": "mean query time"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Database Size",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5368709120 },
              { "color": "orange", "value": 10737418240 },
              { "color": "red", "value": 21474836480 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "pg_database_size_bytes{datname=\"claims\"}",
          "legendFormat": "claims DB"
        }
      ]
    },
    {
      "type": "row",
      "title": "Redis",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false,
      "id": 5
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Redis Connected Clients",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "redis_connected_clients",
          "legendFormat": "connected clients"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "redis_blocked_clients",
          "legendFormat": "blocked clients"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Redis Memory Usage",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "redis_memory_used_bytes",
          "legendFormat": "used"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "redis_memory_max_bytes",
          "legendFormat": "max"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "redis_memory_used_rss_bytes",
          "legendFormat": "RSS"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Redis Hit Rate",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never"
          },
          "color": { "fixedColor": "green", "mode": "fixed" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "min"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(redis_keyspace_hits_total[5m]) / (rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m]))",
          "legendFormat": "hit rate"
        }
      ]
    },
    {
      "type": "row",
      "title": "Kafka",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false,
      "id": 9
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Broker Message Rate",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(kafka_server_brokertopicmetrics_messagesin_total[5m]))",
          "legendFormat": "messages in/s"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(kafka_server_brokertopicmetrics_bytesout_total[5m]))",
          "legendFormat": "bytes out/s"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(kafka_server_brokertopicmetrics_bytesin_total[5m]))",
          "legendFormat": "bytes in/s"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Under-Replicated Partitions",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 20,
            "showPoints": "never"
          },
          "color": { "fixedColor": "red", "mode": "fixed" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["max", "lastNotNull"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(kafka_server_replicamanager_underreplicatedpartitions)",
          "legendFormat": "under-replicated partitions"
        }
      ]
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Topic & Partition Count",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "count(count by (topic) (kafka_server_brokertopicmetrics_messagesin_total))",
          "legendFormat": "Topics"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(kafka_server_replicamanager_partitioncount)",
          "legendFormat": "Partitions"
        }
      ]
    },
    {
      "type": "row",
      "title": "Elasticsearch",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "collapsed": false,
      "id": 13
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Cluster Health",
      "description": "Elasticsearch cluster health status (0=green, 1=yellow, 2=red)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 20,
            "showPoints": "never",
            "thresholdsStyle": { "mode": "area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "GREEN" }, "1": { "text": "YELLOW" }, "2": { "text": "RED" } } }
          ]
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "elasticsearch_cluster_health_status{color=\"yellow\"} * 1 + elasticsearch_cluster_health_status{color=\"red\"} * 2",
          "legendFormat": "cluster status"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "elasticsearch_cluster_health_number_of_nodes",
          "legendFormat": "node count"
        }
      ]
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Index Size",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "elasticsearch_indices_store_size_bytes_total",
          "legendFormat": "total index size"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "elasticsearch_indices_docs_total",
          "legendFormat": "total docs"
        }
      ]
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Search Latency",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(elasticsearch_indices_search_query_time_seconds[5m]) / rate(elasticsearch_indices_search_query_total[5m]) * 1000",
          "legendFormat": "avg query latency"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(elasticsearch_indices_search_fetch_time_seconds[5m]) / rate(elasticsearch_indices_search_fetch_total[5m]) * 1000",
          "legendFormat": "avg fetch latency"
        }
      ]
    }
  ],
  "annotations": {
    "list": []
  }
}